# Backend API base (origin + /api/v1). Dev: http://localhost:4000/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
# Public site origin (used for canonical URLs / sitemap). Dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Admin app ORIGIN for the "Admin Login" link (the link appends /login itself).
# Dev: http://localhost:3001   Production: https://admin.krfuels.com
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# Shared secret for the on-demand revalidation endpoint (POST /api/revalidate).
# Server-side only. Must match the admin app's REVALIDATE_SECRET.
REVALIDATE_SECRET=
