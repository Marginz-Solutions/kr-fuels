# Client (browser) API base. Keep it RELATIVE ("/api/v1") so requests stay
# same-origin and the httpOnly `session` cookie attaches; a Next rewrite
# (next.config.ts) proxies /api/v1/* to the real backend, forwarding the cookie.
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Absolute backend base (origin + /api/v1) — server-side only (session route,
# serverFetch) and the rewrite-proxy destination. Dev: http://localhost:4000/api/v1
BACKEND_API_BASE_URL=http://localhost:4000/api/v1

# Firebase client (browser auth) config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_DB=(default)

# Open self-registration guard. Keep "false" for a public staff admin; flip to
# "true" only long enough to create the first admin account, then revert.
NEXT_PUBLIC_ALLOW_REGISTRATION=false

# In production, the parent cookie domain (e.g. .krfuels.com)
COOKIE_DOMAIN=
