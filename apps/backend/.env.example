# ─── Firebase Admin (server-only secrets) ───────────────────────────────
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the service-account private key with literal \n for newlines, in quotes.
FIREBASE_ADMIN_PRIVATE_KEY=""
FIREBASE_STORAGE_BUCKET=
# Firestore database id (use "(default)" unless a named DB is in use)
FIREBASE_DB=(default)

# ─── Admin access control ───────────────────────────────────────────────
# Comma-separated emails allowed to sign in to the admin panel (case-insensitive).
# Fail closed: if this is empty/unset, ALL admin logins are rejected.
ADMIN_ALLOWLIST=admin@example.com,second.admin@example.com

# ─── CORS / cross-origin auth ───────────────────────────────────────────
# Front-end origins allowed to call the API with credentials.
# Dev: admin panel :3001, public site :3000.
# Production: ADMIN_ORIGIN=https://admin.krfuels.com  USER_ORIGIN=https://krfuels.com
ADMIN_ORIGIN=http://localhost:3001
USER_ORIGIN=http://localhost:3000
# In production set the parent domain so the session cookie is shared, e.g. .krfuels.com
COOKIE_DOMAIN=
