# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (root + per-workspace)
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js (any app)
.next/
out/

# production
build/

# turbo
.turbo/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (committed: only .env.example)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# one-off data/migration scripts (not part of the app)
/tools/
